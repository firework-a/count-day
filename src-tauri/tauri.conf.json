{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "count-day",
  "version": "0.1.4",
  "identifier": "com.firework-a.count-day",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "count-day",
        "width": 440,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": true,
        "devtools": true
      },
      {
        "label": "settings",
        "title": "偏好设置",
        "width": 800,
        "height": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "visible": false,
        "skipTaskbar": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/firework-a/count-day/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGM0NBNzg4ODhDMjgwQTYKUldTbWdNS0lpS2M4TDRQUDg1dDlxQTV3alh3VHB5VHlEcnVyUFFjQlZ2U0UwU3Azem5nMTRjZU0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese"
        ],
        "installMode": "both"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}