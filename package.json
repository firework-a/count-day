{
  "name": "count-day",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "node scripts/update-tauri-config.js --mode=development && vite",
    "dev:test": "node scripts/update-tauri-config.js --mode=test && vite --mode test",
    "build": "node scripts/update-tauri-config.js --mode=production && tsc && vite build && node scripts/generate-update-json.js",
    "build:test": "node scripts/update-tauri-config.js --mode=test && tsc && vite build --mode test",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:app": "pnpm build && pnpm tauri build",
    "build:app:test": "pnpm build:test && pnpm tauri build",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "cross-env CI=true oxlint --fix"
    ]
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxlint": "^1.51.0",
    "sass-embedded": "^1.97.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}